<style>
	.address-alert-overlay {
		align-items: center;
		background: rgba(0, 0, 0, 0.72);
		display: none;
		inset: 0;
		justify-content: center;
		padding: 18px;
		position: fixed;
		z-index: 10000;
	}

	.address-alert-overlay.is-visible {
		display: flex;
	}

	.address-alert-dialog {
		background: #ffffff;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
		max-height: 92vh;
		max-width: 760px;
		padding: 10px;
		position: relative;
		width: min(92vw, 760px);
	}

	.address-alert-dialog img {
		display: block;
		height: auto;
		max-height: calc(92vh - 20px);
		object-fit: contain;
		width: 100%;
	}

	.address-alert-close {
		align-items: center;
		background: #0277bd;
		border: 0;
		border-radius: 50%;
		box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
		color: #ffffff;
		cursor: pointer;
		display: flex;
		height: 42px;
		justify-content: center;
		position: absolute;
		right: -14px;
		top: -14px;
		width: 42px;
		z-index: 1;
	}

	.address-alert-close:focus {
		outline: 3px solid #ffffff;
		outline-offset: 2px;
	}

	body.address-alert-open {
		overflow: hidden;
	}
</style>

<script is:inline>
	const addressAlert = document.querySelector('[data-address-alert]');
	const addressAlertClose = document.querySelector('[data-address-alert-close]');

	const closeAddressAlert = () => {
		addressAlert?.classList.remove('is-visible');
		addressAlert?.setAttribute('aria-hidden', 'true');
		document.body.classList.remove('address-alert-open');
	};

	if (addressAlert) {
		window.setTimeout(() => {
			addressAlert.classList.add('is-visible');
			addressAlert.setAttribute('aria-hidden', 'false');
			document.body.classList.add('address-alert-open');
			addressAlertClose?.focus();
		}, 300);

		addressAlertClose?.addEventListener('click', closeAddressAlert);
		addressAlert.addEventListener('click', (event) => {
			if (event.target === addressAlert) {
				closeAddressAlert();
			}
		});
		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				closeAddressAlert();
			}
		});
	}
</script>
